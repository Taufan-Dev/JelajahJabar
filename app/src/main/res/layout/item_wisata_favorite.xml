<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="4dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="?attr/colorSurfaceVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Tourism Thumbnail Image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivWisataFav"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/hero"
            app:shapeAppearanceOverlay="@style/RoundedImageView" />

        <!-- Info Area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/tvNamaWisataFav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Kawah Putih Ciwidey"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:fontFamily="@font/font_display"
                android:textStyle="bold" />

            <!-- Location Badge -->
            <TextView
                android:id="@+id/tvLokasiFav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="📍 Bandung"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:fontFamily="@font/font_primary"
                android:textStyle="bold|italic" />

            <!-- Rating Area -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="@color/accent_orange" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="4.8 (500+)"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>

        <!-- Love Button icon -->
        <ImageView
            android:id="@+id/ivLoveFav"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="4dp"
            android:padding="4dp"
            android:src="@drawable/ic_heart_filled"
            app:tint="@color/accent_red"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>